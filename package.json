{
  "name": "rsbuild-plugin-pwa",
  "description": "Zero-config PWA support for rsbuild",
  "version": "1.1.0",
  "author": "Ilya Strus <strax1990@gmail.com>",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types/register-sw": {
      "types": "./types/register-sw.d.ts"
    },
    "./types/react": {
      "types": "./types/react.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "vm-dist",
    "types",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/s-r-x/rsbuild-plugin-pwa"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://github.com/s-r-x/rsbuild-plugin-pwa",
  "bugs": {
    "url": "https://github.com/s-r-x/rsbuild-plugin-pwa/issues"
  },
  "keywords": [
    "rsbuild",
    "rsbuild-plugin",
    "pwa"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "lint:fix": "biome lint",
    "lint": "biome lint --write",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check-types": "tsc --noEmit",
    "test": "node ./test/index.test.ts",
    "docs:build": "rspress build",
    "docs:dev": "rspress dev",
    "docs:preview": "rspress preview",
    "sandbox:build": "rsbuild build --root=./sandbox",
    "sandbox:dev": "rsbuild dev --root=./sandbox",
    "sandbox:preview": "rsbuild preview --root=./sandbox",
    "vm:build": "node ./scripts/build-vm.ts",
    "vm:build-types": "node ./scripts/build-vm-types.ts",
    "release": "npx release-it"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@microsoft/api-extractor": "^7.58.5",
    "@release-it/conventional-changelog": "^10.0.6",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-react": "^1.4.6",
    "@rslib/core": "^0.19.6",
    "@rspress/core": "^2.0.6",
    "@rspress/plugin-typedoc": "^2.0.6",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cheerio": "^1.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0 || ^2.0.0-0"
  },
  "dependencies": {
    "@types/web-app-manifest": "^1.0.9",
    "chalk": "^5.6.2",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  }
}
